#!/usr/bin/env zsh
alias bat='bat --color=always --theme=TwoDark'
alias cat=/bin/cat
alias fdf='fd --type f --no-ignore-vcs --hidden --follow --exclude .o --exclude .git'
alias fdd='fd --type d --no-ignore-vcs --hidden --follow --exclude .o --exclude .git'
alias fdall='fd -I -a --hidden --follow --exclude .o --exclude .git'
alias rgg='rg --column --line-number --no-heading --color=always --with-filename --'
alias rgall='rg --no-ignore'
